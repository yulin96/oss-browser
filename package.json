{
  "name": "oss-browser",
  "productName": "OSS Browser",
  "version": "0.0.6",
  "description": "A modern Apple Silicon compatible desktop client for Alibaba Cloud OSS",
  "license": "MIT",
  "main": "./out/main/index.js",
  "author": "yulin96 (https://github.com/yulin96)",
  "homepage": "https://github.com/yulin96/oss-browser",
  "repository": {
    "type": "git",
    "url": "https://github.com/yulin96/oss-browser.git"
  },
  "bugs": {
    "url": "https://github.com/yulin96/oss-browser/issues"
  },
  "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:mac:arm64": "pnpm build && electron-builder --mac --arm64",
    "build:mac:universal": "pnpm build && electron-builder --mac --universal",
    "build:linux": "pnpm build && electron-builder --linux"
  },
  "dependencies": {
    "@alicloud/cdn20180510": "9.2.0",
    "@alicloud/openapi-core": "1.0.7",
    "@alicloud/ram20150501": "1.2.1",
    "@alicloud/sts20150401": "1.2.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@lucide/lab": "0.1.2",
    "@lucide/vue": "^1.24.0",
    "@tailwindcss/vite": "^4.3.2",
    "@vueuse/core": "^14.3.0",
    "ali-oss": "6.23.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "6.6.2",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  }
}
